
menu "App Config"

menuconfig LED_SUBSYSTEM
    bool "LED Subsystem"
    default n

if LED_SUBSYSTEM

choice
    prompt "Led blink sleep time"
    default BLINK_SLEEP_1000MS
    optional

    config BLINK_SLEEP_250MS
    bool "250MS Sleep Time"

    config BLINK_SLEEP_500MS
    bool "500MS Sleep Time"

    config BLINK_SLEEP_1000MS
    bool "1000MS Sleep Time"

    config BLINK_SLEEP_2000MS
    bool "2000MS Sleep Time"

endchoice

menuconfig LED_ADVANCED_SETTINGS
    bool "Advanced LED settings"
    default n

if LED_ADVANCED_SETTINGS

    config LED_BRIGHTNESS
        int "LED brightness"
        default 50
        range 0 100
        help
            LED Brightness from 0% to 100%

    config LED_FADE_DURATION
        int "LED fade duration"
        default 1000
        range 0 5000
        help
            LED fade duration from 0ms to 5000ms

endif   # LED_ADVANCED_SETTINGS

menu "Expert settings"
    visible if LED_ADVANCED_SETTINGS

    config LED_DEBUG
        bool "Enable LED debugging"
        default false

    config LED_CUSTOM_PATTERN
        bool "Custom blink pattern"
        default false

endmenu

endif   # LED_SUBSYSTEM

config LED_BLINK_SLEEP
    int 
    default 2000 if BLINK_SLEEP_2000MS
    default 1000 if BLINK_SLEEP_1000MS
    default 500  if BLINK_SLEEP_500MS
    default 250  if BLINK_SLEEP_250MS
    range 0 2000
    help
      Led blinking sleep time


endmenu

menu "Zephyr Config"
source "Kconfig.zephyr"
endmenu